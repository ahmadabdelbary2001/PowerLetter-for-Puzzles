{
  "name": "powerletter-monorepo",
  "author": "Ahmad Abdelbary",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @powerletter/web dev",
    "dev:desktop": "pnpm --filter @powerletter/desktop-mobile dev",
    "tauri": "pnpm --filter @powerletter/desktop-mobile tauri",
    "tauri:dev": "pnpm --filter @powerletter/desktop-mobile tauri:dev",
    "tauri:build": "pnpm --filter @powerletter/desktop-mobile tauri:build",
    "android:dev": "pnpm --filter @powerletter/desktop-mobile android:dev",
    "android:build": "pnpm --filter @powerletter/desktop-mobile android:build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.1.2",
    "typescript": "~5.8.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
