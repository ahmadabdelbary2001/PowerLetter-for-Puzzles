{
  "extends": "@powerletter/config/typescript",
  "compilerOptions": {
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@ui/*": ["./src/*"],
      "@core/*": ["../core/src/*"],
      "@powerletter/core": ["../core/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
