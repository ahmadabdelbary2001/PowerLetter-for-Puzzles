{
  "extends": "@powerletter/config/typescript",
  "compilerOptions": {
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "../../data/**/*"]
}
