{
  "extends": "@powerletter/config/typescript",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "types": ["react", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["../../packages/core/src/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@powerletter/core": ["../../packages/core/src/index.ts"],
      "@powerletter/ui": ["../../packages/ui/src/index.ts"],
      "@powerletter/api-bindings": ["../../packages/api-bindings/src/index.ts"]
    }
  },
  "include": ["src"]
}
