{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PowerLetter for Puzzles",
  "version": "1.0.8",
  "identifier": "com.powerletter.puzzles",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "PowerLetter for Puzzles",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Ahmad Abdelbary",
    "icon": [
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true
      }
    },
    "resources": [
      "WebView2Loader.dll"
    ]
  }
}
